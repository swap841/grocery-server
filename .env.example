# Server port
PORT=3000

# Firebase Admin SDK
# Option 1: Set FIREBASE_SERVICE_ACCOUNT_BASE64 (base64-encoded service account JSON) — required for Render
# Option 2: Place serviceAccountKey.json in this folder (for local dev only)
FIREBASE_SERVICE_ACCOUNT_BASE64=

# Server base URL (for CORS / callbacks)
# SERVER_URL=https://server-qtp4.onrender.com
