PORT=3000
NODE_ENV=development
LOG_LEVEL=info

# Firebase Admin — set base64 for Render, or place serviceAccountKey.json locally
FIREBASE_SERVICE_ACCOUNT_BASE64=

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# CORS — comma-separated allowed origins
ALLOWED_ORIGINS=https://customer-website.vercel.app,https://owner-dashboard.vercel.app,https://server-qtp4.onrender.com

# API key for webhook endpoints
API_KEY=replace-with-random-secure-string
