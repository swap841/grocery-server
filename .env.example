PORT=3000
NODE_ENV=development
LOG_LEVEL=info

# Firebase Admin — set base64 for Render, or place serviceAccountKey.json locally
FIREBASE_SERVICE_ACCOUNT_BASE64=

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# CORS — comma-separated allowed origins
ALLOWED_ORIGINS=https://grocery-server-u2qq.onrender.com,https://customer-website-1.onrender.com,https://owner-dashboard-j73k.onrender.com

# API key for webhook endpoints
API_KEY=replace-with-random-secure-string

# Razorpay Keys
RAZORPAY_KEY_ID=rzp_test_...
RAZORPAY_KEY_SECRET=...

# ImgBB API Key (for /api/upload-photo proxy)
IMGBB_API_KEY=your_imgbb_api_key_here

# MSG91 SMS (for /api/notify-owner)
MSG91_AUTH_KEY=
MSG91_FLOW_ID=
OWNER_PHONE=

# Allowed owner emails (for /api/set-owner)
ALLOWED_OWNER_EMAILS=youremail@gmail.com

# Admin key for owner-protected endpoints (e.g., POST /api/config)
ADMIN_KEY=your-random-admin-key

# Cache clear API key (owner dashboard sends this to clear product cache)
CACHE_CLEAR_KEY=your-random-cache-key
